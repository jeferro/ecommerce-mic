{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ecommerce [clean build test]",
      "type": "shell",
      "command": "gradle",
      "args": [
        "clean",
        "build",
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}/code"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [
        "$gradle"
      ]
    },
    {
      "label": "ecommerce [env up]",
      "type": "shell",
      "command": "task",
      "args": [
        "env-up"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    }
  ]
}


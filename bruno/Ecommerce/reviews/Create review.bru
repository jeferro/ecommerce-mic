meta {
  name: Create review
  type: http
  seq: 2
}

post {
  url: {{ecommerce-url}}/v1/reviews
  body: json
  auth: bearer
}

headers {
  Accept-Language: {{accept-language}}
}

auth:bearer {
  token: {{ecommerce-jwt-token}}
}

body:json {
  {
      "entityId": "products::banana",
      "comment": "I prefer pineapple"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

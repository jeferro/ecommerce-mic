meta {
  name: Update review
  type: http
  seq: 4
}

patch {
  url: {{ecommerce-url}}/v1/reviews/:reviewId
  body: json
  auth: bearer
}

params:path {
  reviewId: user::products::apple
}

headers {
  Accept-Language: {{accept-language}}
}

auth:bearer {
  token: {{ecommerce-jwt-token}}
}

body:json {
  {
      "comment": "I eat pinepaple everyday"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

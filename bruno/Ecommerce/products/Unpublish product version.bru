meta {
  name: Unpublish product version
  type: http
  seq: 7
}

put {
  url: {{ecommerce-url}}/v1/products/:productCode/versions/:effectiveDate/unpublished
  body: json
  auth: bearer
}

params:path {
  productCode: pineapple
  effectiveDate: 2025-01-14T09:00:00.00Z
}

headers {
  Accept-Language: {{accept-language}}
}

auth:bearer {
  token: {{ecommerce-jwt-token}}
}

body:json {
  {
      "version": {{product-version}}
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

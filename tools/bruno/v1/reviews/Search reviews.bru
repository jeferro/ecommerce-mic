meta {
  name: Search reviews
  type: http
  seq: 1
}

get {
  url: {{ecommerce-url}}/v1/reviews?pageSize=10&pageNumber=0&order=ID
  body: none
  auth: bearer
}

params:query {
  pageSize: 10
  pageNumber: 0
  order: ID
  ~ascending: 
  ~entityId: products::apple
}

headers {
  Accept-Language: {{proc-users-url}}
}

auth:bearer {
  token: {{ecommerce-jwt-token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

meta {
  name: Search product version ids
  type: http
  seq: 4
}

get {
  url: {{ecommerce-url}}/v1/products/:productCode/versions?pageNumber=0&pageSize=10
  body: none
  auth: bearer
}

params:query {
  pageNumber: 0
  pageSize: 10
}

params:path {
  productCode: pineapple
}

headers {
  ~Accept-Language: {{accept-language}}
}

auth:bearer {
  token: {{ecommerce-jwt-token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
